<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="620.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.EmployeeController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>

                <!-- Inputfelter i en række -->
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="nameTxt" prefWidth="100.0" promptText="Navn" />
                        <TextField fx:id="emailTxt" prefWidth="100.0" promptText="Email" />
                  <TextField fx:id="roleTxt" maxWidth="-Infinity" prefWidth="100.0" promptText="Role" />
                  <TextField fx:id="userTxt" maxWidth="-Infinity" prefWidth="100.0" promptText="Username" />
                  <TextField fx:id="passwordTxt" maxWidth="-Infinity" prefWidth="100.0" promptText="Password" />
                    </children>
                </HBox>

                <!-- Knapper i en række -->
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="createButton" mnemonicParsing="false" onAction="#onCreate" prefWidth="130.0" text="Opret employee" />
                        <Button fx:id="changeButton" mnemonicParsing="false" prefWidth="130.0" text="Ret employee" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" prefWidth="130.0" text="Fjerne employee" />
                    </children>
                </HBox>

                <!-- Fejlbesked -->
                <Label fx:id="labelException" textFill="red" />

                <!-- Tabel fylder resten -->
                <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="Id" />
                        <TableColumn fx:id="colName" text="Navn" />
                        <TableColumn fx:id="colEmail" text="Email" />
                        <TableColumn fx:id="colTreatment" text="Role" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>
