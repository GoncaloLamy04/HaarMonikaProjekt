<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.CreateBookingController">
   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>

            <HBox spacing="10.0">
               <children>
                  <VBox spacing="3.0">
                     <Label text="Navn"/>
                     <TextField fx:id="nameTxt" prefWidth="110.0"/>
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Email"/>
                     <TextField fx:id="emailTxt" prefWidth="150.0"/>
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Behandling"/>
                     <ComboBox fx:id="treatmentCombo" prefWidth="160.0"/>
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Tid"/>
                     <ComboBox fx:id="timeCombo" prefWidth="100.0"/>
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Dato"/>
                     <DatePicker fx:id="timeDate" prefWidth="140.0"/>
                  </VBox>
               </children>
            </HBox>

            <TextField fx:id="durationTxt" visible="false" managed="false"/>

            <HBox spacing="10.0">
               <children>
                  <Button fx:id="createButton" mnemonicParsing="false" prefWidth="130.0" text="Opret booking" onAction="#onCreateBooking"/>
                  <Button fx:id="changeButton" mnemonicParsing="false" prefWidth="130.0" text="Ret booking" onAction="#onChangeBooking"/>
                  <Button fx:id="deleteButton" mnemonicParsing="false" prefWidth="130.0" text="Aflys booking" onAction="#onDeleteBooking"/>
                  <TextField fx:id="searchField" prefHeight="26.0" prefWidth="100.0" promptText="Søg navn..."/>
                  <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="26.0" prefWidth="60.0" text="Søg"/>
                  <Button mnemonicParsing="false" onAction="#clearSearch" prefHeight="26.0" prefWidth="60.0" text="Ryd"/>
               </children>
            </HBox>

            <Label fx:id="labelException" textFill="red"/>

            <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colId" text="Id" prefWidth="40"/>
                  <TableColumn fx:id="colName" text="Navn" prefWidth="100"/>
                  <TableColumn fx:id="colEmail" text="Email" prefWidth="130"/>
                  <TableColumn fx:id="colTreatment" text="Behandling" prefWidth="150"/>
                  <TableColumn fx:id="colTime" text="Tid" prefWidth="130"/>
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
               </columnResizePolicy>
            </TableView>

         </children>
      </VBox>
   </children>
</AnchorPane>