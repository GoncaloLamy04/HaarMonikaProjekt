<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.LoginController">
   <children>
      <VBox layoutX="6.0" layoutY="76.0" prefHeight="200.0" prefWidth="596.0">
         <children>
            <TextField fx:id="userTxt" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="250.0" promptText="Username">
               <VBox.margin>
                  <Insets left="165.0" top="20.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="passTxt" maxWidth="-Infinity" prefHeight="25.0" prefWidth="250.0" promptText="Password">
               <VBox.margin>
                  <Insets left="165.0" top="15.0" />
               </VBox.margin>
            </TextField>
            <Button fx:id="loginButton" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onLogin" prefWidth="100.0" text="Login">
               <VBox.margin>
                  <Insets left="240.0" top="25.0" />
               </VBox.margin>
            </Button>
            <Label fx:id="labelException">
               <VBox.margin>
                  <Insets left="240.0" />
               </VBox.margin>
            </Label>
         </children>
      </VBox>
   </children>
</AnchorPane>
